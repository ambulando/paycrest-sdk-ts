{
  "name": "@paycrest/sdk",
  "version": "0.0.1",
  "description": "TypeScript SDK for the Paycrest API (Sender integration)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "paycrest",
    "sdk",
    "stablecoin",
    "offramp",
    "onramp",
    "crypto"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
